# --- Virtual Environments ---
.env

# --- IDEs & Editors ---
.idea/
.vscode/
/.git/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs & Debug ---
*.log
logs/
logs_*/           # Ignore all log folders (logs_fashion_grid, etc.)
wandb/            # Local Weights & Biases folder (large)

# --- Data & Outputs ---
data/
datasets/
results/
outputs/          # Docker-mounted volume
benchmark_results/
cache/

# --- Checkpoints & Models ---
checkpoints/
checkpoints_svm/  # Default folder for EnhancedSVM
*.pt
*.pth
*.pkl
*.ckpt

# --- Project-specific Caches (IMPORTANT) ---
kernel_cache/     # Exclude: quantum kernel matrices (.npy)
*.npy             # Safety: ignore standalone numpy files

# --- Docker ---
.dockerignore