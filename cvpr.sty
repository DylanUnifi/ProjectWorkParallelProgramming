% cvpr.sty — minimal CVPR-style package for local compilation
% Provides the minimal set of macros expected by CVPR-formatted papers.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{cvpr}[2024/01/01 Minimal CVPR style]

\newif\ifcvprfinal
\cvprfinalfalse
\DeclareOption{final}{\cvprfinaltrue}
\ProcessOptions\relax

% Command defined by CVPR template
\newcommand{\cvprfinalcopy}{\cvprfinaltrue}

% Geometry and margins (CVPR standard: letter, 1in margins, two-column)
\RequirePackage{geometry}
\geometry{
  letterpaper,
  top=1in,
  bottom=1in,
  left=0.75in,
  right=0.75in,
  columnsep=0.25in
}

% Section heading style
\RequirePackage{titlesec}
\titleformat{\section}{\normalfont\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalfont\normalsize\bfseries}{\thesubsection}{1em}{}

% Abstract styling
\renewenvironment{abstract}{%
  \begin{center}%
    \bfseries Abstract%
  \end{center}%
  \begin{quotation}\noindent\small
}{%
  \end{quotation}%
}

% Hyperref (optional, don't break if not loaded)
\IfFileExists{hyperref.sty}{%
  \RequirePackage{hyperref}%
  \hypersetup{colorlinks=true, linkcolor=blue, citecolor=blue, urlcolor=blue}%
}{}

% Useful utilities
\newcommand{\eg}{\emph{e.g}\onedot}
\newcommand{\ie}{\emph{i.e}\onedot}
\newcommand{\cf}{\emph{cf}\onedot}
\newcommand{\etc}{\emph{etc}\onedot}
\newcommand{\vs}{\emph{vs}\onedot}
\newcommand{\onedot}{.\@}
